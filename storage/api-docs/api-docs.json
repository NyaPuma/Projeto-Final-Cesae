                    }
                },
                "security": [
                    {
                        "X-Auth-Token": []
                    },
                    {
                        "BearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Tickets"
                ],
                "summary": "Criar ticket",
                "description": "Cria um novo ticket de avaria.\n- Apenas utilizadores comuns (`ROLE_USER`) podem criar.\n- Valida título/descrição e a atividade do equipamento/sala.",
                "operationId": "f9282cd452389d3cc5d06f0cf782b672",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "title",
                                    "description"
                                ],
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "Projetor não liga"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "O projetor da sala 4 não responde."
                                    },
                                    "equipment_id": {
                                        "type": "integer",
                                        "example": 12,
                                        "nullable": true
                                    },
                                    "room_id": {
                                        "type": "integer",
                                        "example": 3,
                                        "nullable": true
                                    },
                                    "priority": {
                                        "type": "string",
                                        "example": "alta"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Ticket criado"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                },
                "security": [
                    {
                        "X-Auth-Token": []
                    },
                    {
                        "BearerAuth": []
                    }
                ]
            }
