        "/tickets": {
            "get": {
                "tags": [
                    "Tickets"
                ],
                "summary": "Listar tickets",
                "description": "Lista todos os tickets aplicando os filtros definidos.\n- Utilizadores normais veem exclusivamente os seus próprios tickets.\n- Técnicos e Administradores têm visibilidade global sobre os registos.",
